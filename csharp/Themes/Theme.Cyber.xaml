<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ── Cyber (default dark) ───────────────────────────── -->
    <SolidColorBrush x:Key="BgBrush"       Color="#10121a"/>
    <SolidColorBrush x:Key="SurfaceBrush"  Color="#161b26"/>
    <SolidColorBrush x:Key="SubtleBrush"   Color="#1a1c24"/>
    <SolidColorBrush x:Key="BorderBrush"   Color="#222840"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="#4fa8c5"/>
    <SolidColorBrush x:Key="Accent2Brush"  Color="#2d6a82"/>
    <SolidColorBrush x:Key="TextBrush"     Color="#a8b4cc"/>
    <SolidColorBrush x:Key="TextDimBrush"  Color="#556070"/>
