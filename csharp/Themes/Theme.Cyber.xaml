    <SolidColorBrush x:Key="GreenBrush"    Color="#4a9e72"/>
    <SolidColorBrush x:Key="RedBrush"      Color="#b85555"/>
    <SolidColorBrush x:Key="YellowBrush"   Color="#b8913a"/>
    <SolidColorBrush x:Key="TransBrush"    Color="Transparent"/>
    <SolidColorBrush x:Key="HoverBg"       Color="#0a1520"/>
    <SolidColorBrush x:Key="SelectBg"      Color="#0d2030"/>
