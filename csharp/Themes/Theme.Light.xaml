<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ── Clean Light / SaaS ────────────────────────────── -->
    <SolidColorBrush x:Key="BgBrush"       Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceBrush"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubtleBrush"   Color="#F1F5F9"/>
    <SolidColorBrush x:Key="BorderBrush"   Color="#E2E8F0"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="#3B82F6"/>
    <SolidColorBrush x:Key="Accent2Brush"  Color="#2563EB"/>
    <SolidColorBrush x:Key="TextBrush"     Color="#0F172A"/>
    <SolidColorBrush x:Key="TextDimBrush"  Color="#94A3B8"/>
