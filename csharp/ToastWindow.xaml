<Window x:Class="ScalanceLogs.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Width="300"
        Focusable="False"
        IsHitTestVisible="True">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="0"
            MinWidth="260" MaxWidth="300">

        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.55"
                              BlurRadius="14" ShadowDepth="3" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>

            <!-- Severity accent bar -->
            <Border x:Name="AccentBar" Grid.Column="0"
                    Background="{DynamicResource AccentBrush}"
                    CornerRadius="4 0 0 4"/>

            <!-- Content -->
            <StackPanel Grid.Column="1" Margin="10 9 4 9">
                <TextBlock x:Name="TitleText"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0 0 0 3"/>
                <TextBlock x:Name="MessageText"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="60"/>
            </StackPanel>

            <!-- Close button -->
            <TextBlock Grid.Column="2"
                       Text="✕"
                       FontSize="10"
                       Foreground="{DynamicResource TextDimBrush}"
                       VerticalAlignment="Top"
                       Margin="0 7 4 0"
                       Cursor="Hand"
                       MouseLeftButtonUp="Close_Click">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</Window>
