{
  "UdpPort": 5140,
  "LogRetentionDays": 30,
  "LogPath": "logs",
  "AutoStart": false,
  "BalloonNotifications": true,
  "SwitchNames": [],
  "EventPatterns": [
    "link\\s\u002B(up|down)",
    "port.*(up|down)",
    "(fault|error|fail)"
  ],
  "MessageTypes": [
    {
      "Pattern": "link\\s\u002Bdown",
      "Label": "LINK DOWN",
      "Color": "#ff6b6b",
      "Bg": "rgba(255,107,107,0.15)"
    },
    {
      "Pattern": "link\\s\u002Bup",
      "Label": "LINK UP",
      "Color": "#4a9e72",
      "Bg": "rgba(74,158,114,0.12)"
    },
    {
      "Pattern": "time synchronized",
      "Label": "NTP SYNC",
      "Color": "#4fa8c5",
      "Bg": "rgba(79,168,197,0.10)"
    },
    {
      "Pattern": "time not synchronized",
      "Label": "NTP LOST",
      "Color": "#b8913a",
      "Bg": "rgba(184,145,58,0.12)"
    },
    {
      "Pattern": "configuration changed",
      "Label": "CFG CHG",
      "Color": "#b8913a",
      "Bg": "rgba(184,145,58,0.10)"
    },
    {
      "Pattern": "logged in",
      "Label": "LOGIN",
      "Color": "#a8b4cc",
      "Bg": "rgba(168,180,204,0.08)"
    },
    {
      "Pattern": "logged out|inactivity",
      "Label": "LOGOUT",
      "Color": "#556070",
      "Bg": "rgba(85,96,112,0.10)"
    },
    {
      "Pattern": "log file cleared",
      "Label": "LOG CLR",
      "Color": "#556070",
      "Bg": "rgba(85,96,112,0.08)"
    },
    {
      "Pattern": "pattern",
      "Label": "LABEL",
      "Color": "#a8b4cc",
      "Bg": "rgba(168,180,204,0.08)"
    }
  ],
  "QuickFilters": [
    {
      "Label": "Link",
      "Query": "link"
    },
    {
      "Label": "NTP",
      "Query": "ntp"
    },
    {
      "Label": "Admin",
      "Query": "admin"
    },
    {
      "Label": "Config",
      "Query": "configuration"
    }
  ]
}