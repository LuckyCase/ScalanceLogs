<Window x:Class="ScalanceLogs.ThemeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScalanceLogs"
        Title="Edit Theme" Height="600" Width="480"
        MinHeight="480" MinWidth="380"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Group header row -->
        <DataTemplate DataType="{x:Type local:ThemeGroupRow}">
            <TextBlock Text="{Binding Title}"
                       FontFamily="Consolas" FontSize="10"
                       Foreground="{DynamicResource TextDimBrush}"
                       Margin="0 14 0 4"/>
        </DataTemplate>

        <!-- Color entry row -->
        <DataTemplate DataType="{x:Type local:ThemeColorRow}">
            <Grid Margin="0 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Label}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="PickColor_Click" Tag="{Binding}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalAlignment="Left" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Swatch" Width="26" Height="26" CornerRadius="4"
                                Background="{Binding SwatchBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0 0 8 0"/>
                        <TextBlock Text="{Binding Hex}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

        <!-- ── Footer buttons ─────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0 1 0 0" Padding="16 10">
            <Grid>
                <Button Content="Reset to Defaults" HorizontalAlignment="Left"
                        Click="Reset_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="80" Margin="0 0 8 0"
                            Click="Cancel_Click"/>
                    <Button Content="Save" Width="80"
                            Style="{StaticResource AccentBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Color list ──────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24 16">
            <ItemsControl x:Name="ColorList">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
