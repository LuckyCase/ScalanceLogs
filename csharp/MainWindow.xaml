<Window x:Class="SyslogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SyslogViewer"
        Title="SW-LOG" Height="700" Width="1200"
        MinHeight="480" MinWidth="700"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- header -->
            <RowDefinition Height="Auto"/> <!-- toolbar -->
            <RowDefinition Height="30"/>   <!-- stats -->
            <RowDefinition Height="*"/>    <!-- main layout -->
            <RowDefinition Height="26"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1">
            <Grid Margin="20 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Syslog Viewer" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Industrial Switch Monitor" FontFamily="Consolas"
                               FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0 0 6 0"
                             Fill="{DynamicResource MutedBrush}"/>
                    <TextBlock x:Name="StatusLabel" Text="—" FontFamily="Consolas" FontSize="12"
                               Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Toolbar ────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1"
                Padding="16 8">
            <WrapPanel Orientation="Horizontal">

                <!-- Search -->
                <Grid Width="260" Margin="0 0 8 0">
                    <TextBox x:Name="SearchBox" Padding="28 5 8 5"
                             FontFamily="Consolas" FontSize="13"
                             Tag="Search..."
                             KeyDown="SearchBox_KeyDown"/>
                    <TextBlock IsHitTestVisible="False" Text="⌕" Margin="8 0 0 0"
                               FontSize="14" Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Quick filters (populated in code-behind) -->
                <WrapPanel x:Name="QuickFiltersPanel" Orientation="Horizontal" Margin="0 0 8 0"/>

                <!-- Line count -->
                <ComboBox x:Name="LineCountBox" Width="110" Margin="0 0 8 0"
                          SelectionChanged="LineCountBox_Changed">
                    <ComboBoxItem Content="50 lines"   Tag="50"/>
                    <ComboBoxItem Content="100 lines"  Tag="100"/>
                    <ComboBoxItem Content="200 lines"  Tag="200" IsSelected="True"/>
                    <ComboBoxItem Content="500 lines"  Tag="500"/>
                    <ComboBoxItem Content="1000 lines" Tag="1000"/>
                </ComboBox>

                <!-- Refresh -->
                <Button Content="↻  Refresh" Margin="0 0 6 0" Click="RefreshBtn_Click"/>

                <!-- Auto-scroll -->
                <Button x:Name="AutoScrollBtn" Content="⇈  AutoScroll" Margin="0 0 6 0"
                        Click="AutoScrollBtn_Click"/>

                <Separator Style="{StaticResource {x:Type Separator}}"
                           Width="1" Height="20" Margin="4 0 10 0"
                           Background="{DynamicResource BorderBrush}"/>

                <!-- Settings -->
                <Button Content="⚙  Settings" Click="SettingsBtn_Click"/>
            </WrapPanel>
        </Border>

        <!-- ── Stats bar ──────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{DynamicResource SubtleBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1"
                Padding="20 0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                    Lines: <Run x:Name="StatTotal" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold">—</Run>
                </TextBlock>
                <TextBlock Margin="20 0 0 0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                    Errors: <Run x:Name="StatErr" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold">—</Run>
                </TextBlock>
                <TextBlock Margin="20 0 0 0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                    Warnings: <Run x:Name="StatWarn" Foreground="{DynamicResource YellowBrush}" FontWeight="SemiBold">—</Run>
                </TextBlock>
                <TextBlock Margin="20 0 0 0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                    Link Down: <Run x:Name="StatDown" Foreground="{DynamicResource RedBrush}" FontWeight="SemiBold">—</Run>
                </TextBlock>
                <TextBlock Margin="20 0 0 0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextDimBrush}">
                    Link Up: <Run x:Name="StatUp" Foreground="{DynamicResource GreenBrush}" FontWeight="SemiBold">—</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Main 3-panel layout ────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="210" MinWidth="0"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition x:Name="LiveCol" Width="270" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar: file tree ──────────────────────────── -->
            <Grid Grid.Column="0">
                <!-- Strip shown when collapsed -->
                <Border x:Name="SidebarStrip"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 1 0"
                        Visibility="Collapsed" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button Content="▶" Click="CollapseSidebar_Click"
                            Width="28" VerticalAlignment="Top" Margin="0 8 0 0"
                            Padding="0" FontSize="10" BorderThickness="0"
                            Background="Transparent"
                            Foreground="{DynamicResource TextDimBrush}"/>
                </Border>
                <!-- Full content shown when expanded -->
                <Border x:Name="SidebarFull"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 1 0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0 0 0 1" Padding="12 7">
                            <DockPanel>
                                <TextBlock Text="LOG FILES" FontFamily="Consolas" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="◀" Width="22" Height="18"
                                        Padding="0" FontSize="10"
                                        Click="CollapseSidebar_Click" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                        <TreeView x:Name="FileTree" BorderThickness="0"
                                  SelectedItemChanged="FileTree_SelectedItemChanged">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Switches}">
                                    <TextBlock Text="{Binding Header}"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               FontFamily="Consolas" FontSize="12" Padding="2 2"/>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Display}"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       FontFamily="Consolas" FontSize="12" Padding="2 2"/>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Sidebar splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" Cursor="SizeWE"/>

            <!-- ── Log entries ─────────────────────────────────── -->
            <Border Grid.Column="2">
                <ItemsControl x:Name="LogList"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer x:Name="LogScroll" CanContentScroll="True">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{Binding RowBorder}" BorderThickness="2 0 0 0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{Binding RowBg}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <!-- Main log line -->
                                    <Grid Margin="4 2 16 2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>   <!-- expand -->
                                            <ColumnDefinition Width="148"/>  <!-- timestamp -->
                                            <ColumnDefinition Width="82"/>   <!-- chip -->
                                            <ColumnDefinition Width="190"/>  <!-- host -->
                                            <ColumnDefinition Width="*"/>    <!-- message -->
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="{Binding IsExpanded, Converter={StaticResource ExpandArrow}}"
                                                FontFamily="Consolas" FontSize="10"
                                                Foreground="{DynamicResource TextDimBrush}"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="0" Width="16" Height="16"
                                                Click="ExpandBtn_Click"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Timestamp}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="2" Margin="2 1"
                                                Background="{Binding ChipBg}"
                                                CornerRadius="2" Padding="5 2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding ChipLabel}"
                                                       Foreground="{Binding ChipFg}"
                                                       FontFamily="Consolas" FontSize="11"/>
                                        </Border>
                                        <!-- Host: IP as hyperlink + suffix
                                             Registered  → cyan hyperlink to https://<ip>
                                             Unregistered → italic dim text + ⓘ tooltip
                                        -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <!-- Registered: clickable hyperlink -->
                                            <TextBlock FontFamily="Consolas" FontSize="12"
                                                       Visibility="{Binding IsUnregistered, Converter={StaticResource InvBoolToVis}}">
                                                <Hyperlink NavigateUri="{Binding IpPart,
                                                           StringFormat='https://{0}'}"
                                                           RequestNavigate="Hyperlink_Navigate"
                                                           Foreground="{DynamicResource AccentBrush}">
                                                    <Run Text="{Binding IpPart}"/>
                                                </Hyperlink>
                                            </TextBlock>
                                            <TextBlock Text="{Binding HostSuffix}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Visibility="{Binding IsUnregistered, Converter={StaticResource InvBoolToVis}}"/>

                                            <!-- Unregistered: plain italic dim text + ⓘ marker -->
                                            <TextBlock Text="{Binding IpPart}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       FontStyle="Italic"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       Visibility="{Binding IsUnregistered, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text=" ⓘ" FontSize="11"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       Cursor="Help"
                                                       ToolTip="Unregistered switch — add a friendly name in Settings → Switches"
                                                       Visibility="{Binding IsUnregistered, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Message}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Expanded raw row -->
                                    <TextBlock Margin="44 0 16 4"
                                               Text="{Binding Raw}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               TextWrapping="Wrap"
                                               Background="{DynamicResource SubtleBrush}"
                                               Padding="6 4"
                                               Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Live panel splitter -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" Cursor="SizeWE"/>

            <!-- ── Live panel ──────────────────────────────────── -->
            <Grid Grid.Column="4">
                <!-- Strip shown when collapsed -->
                <Border x:Name="LiveStrip"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1 0 0 0"
                        Visibility="Collapsed" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button Content="◀" Click="CollapseLive_Click"
                            Width="28" VerticalAlignment="Top" Margin="0 8 0 0"
                            Padding="0" FontSize="10" BorderThickness="0"
                            Background="Transparent"
                            Foreground="{DynamicResource TextDimBrush}"/>
                </Border>
                <!-- Full content shown when expanded -->
                <Border x:Name="LiveFull"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1 0 0 0">
                    <DockPanel>
                        <!-- Header -->
                        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0 0 0 1" Padding="10 7">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="▶" Width="22" Height="18"
                                        Padding="0" FontSize="10" Margin="6 0 0 0"
                                        Click="CollapseLive_Click"/>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource PressedBg}"
                                        CornerRadius="10" Padding="6 1" VerticalAlignment="Center">
                                    <TextBlock x:Name="LiveBadge" Text="0"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <TextBlock Text="LIVE EVENTS" FontFamily="Consolas" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- Active switches -->
                        <Border DockPanel.Dock="Top" x:Name="SwitchSection"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1"
                                MaxHeight="130" MinHeight="36">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="SWITCHES"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           Margin="12 5"/>
                                <ItemsControl x:Name="SwitchList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12 3">
                                                <Ellipse Width="5" Height="5"
                                                         Fill="{DynamicResource AccentBrush}" Margin="0 0 6 0"/>
                                                <TextBlock Text="{Binding}"
                                                           FontFamily="Consolas" FontSize="12"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <!-- Live feed -->
                        <ListBox x:Name="LiveFeed" BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Opacity" Value="{Binding Opacity}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{Binding RowBorder}" BorderThickness="2 0 0 0"
                                            Padding="10 4" Opacity="{Binding Opacity}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding TimeStr}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="{DynamicResource TextDimBrush}"/>
                                                <TextBlock Text=" " FontSize="11"/>
                                                <TextBlock Text="{Binding SwitchName}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0 2 0 0">
                                                <Border Background="{Binding ChipBg}" CornerRadius="2"
                                                        Padding="4 1" Margin="0 0 5 0">
                                                    <TextBlock Text="{Binding ChipLabel}"
                                                               Foreground="{Binding ChipFg}"
                                                               FontFamily="Consolas" FontSize="10"/>
                                                </Border>
                                                <TextBlock Text="{Binding Message}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 1 0 0"
                Padding="20 0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="Industrial Syslog Collector"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}"/>
                <TextBlock x:Name="FooterFile" Text="—"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}" Margin="20 0 0 0"/>
                <TextBlock DockPanel.Dock="Right" Text="IVTI"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
